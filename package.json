{
  "name": "meta-web-three-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "skip-postinstall": "cd ./turbo-module/appsdk && yarn install",
    "start": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "eandroid": "expo start --android",
    "android": "expo run:android",
    "android:cache": "expo run:android --no-build",
    "eios": "expo start --ios",
    "ios": "expo run:ios",
    "ios:cache": "expo run:ios --no-build",
    "rebuild": "expo prebuild --clean",
    "web": "expo start --web",
    "create:module": "npx create-expo-module MyModule",
    "create:sdk": "npx create-react-native-library@latest ../turbo-module/MyModule",
    "lint": "expo lint",
    "update:sdk": "yarn upgrade react-native-appsdk",
    "open:AndroidStudio": "open -a '/Applications/Android Studio.app' ./android",
    "edit:ios": "opeopen netawebthreeapp.xcworkspace",
    "edit:ios:module": "opeopen ./turbo-module/appsdk/ios/AppdkExample.xcworkspace",
    "check:expo:dep": "expo install --check",
    "check:config": "npx react-native config",
    "deploy:config": "eas build:configure",
    "deploy:init": "eas init",
    "generate:android:key": "keytool -genkeypair -v -storetype PKCS12 -keystore keys/android.jks -alias android-key -keyalg RSA -keysize 2048 -validity 10000",
    "manage:android:key": "eas credentials",
    "preview": "eas build --local --profile preview --platform all",
    "deploy:android": "export NODE_ENV=production && eas build --local --platform android",
    "deploy:ios": "export NODE_ENV=production && eas build --local --platform ios",
    "deploy": "export NODE_ENV=production && eas build --local --profile production --platform all",
    "pod": "RCT_NEW_ARCH_ENABLED=1 npx pod-install",
    "ios:upload": "eas submit --platform ios --profile production",
    "android:upload": "eas submit --platform android --profile production"
  },
  "workspaces": [
    "turbo-module/*"
  ],
  "dependencies": {
    "@expo/plist": "^0.3.5",
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "axios": "^1.14.0",
    "expo": "^54.0.0",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-appsdk": "*",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "^0.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/cli": "^0.24.20",
    "@types/react": "~19.1.10",
    "eas-cli": "^16.14.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "react-native-monorepo-config": "^0.1.9",
    "typescript": "~5.9.2"
  },
  "resolutions": {
    "@expo/cli": "^0.24.20"
  },
  "private": true
}
